# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=livepdf
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# SendGrid (Optional fallback / Production recommendation)
# If SENDGRID_API_KEY is present, SendGrid will be used instead of Gmail SMTP
# SENDGRID_API_KEY=SG.your_api_key_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
